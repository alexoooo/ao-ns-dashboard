{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],

    "baseUrl": ".",
    "paths": {
      "N/*": ["node_modules/@hitc/netsuite-types/N/*"],
      "separators": ["src/shared/separators"],
      "api": ["src/client/api.client"],
      "csv": ["src/client/csv.client"],
      "bulk-runner": ["src/client/bulk-runner.client"],
      "edit-records": ["src/pages/edit-records/page.client"],
      "record-type": ["src/pages/record-type/page.client"],
      "record-details": ["src/pages/record-details/page.client"],
      "suiteql": ["src/pages/suiteql/page.client"]
    },

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": false,

    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "experimentalDecorators": false,

    "allowImportingTsExtensions": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "rollup.config.ts", "vitest.config.ts", "eslint.config.js"],
  "exclude": ["node_modules", "ao-ns-dashboard.js"]
}
