{
  "name": "ao-ns-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "NetSuite SuiteScript 2.1 administration & automation dashboard (Suitelet).",
  "keywords": [
    "netsuite",
    "suitelet",
    "suitescript",
    "automation",
    "admin",
    "lit"
  ],
  "author": "Aleksander Ostrovski (Alex Ostrovsky)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexoooo/ao-ns-dashboard"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test"
  },
  "comments": {
    "version": "Real user-visible version is in src/constants.ts. The package.json version is unused (this project is private and not published to npm)."
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@hitc/netsuite-types": "^2024.1.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.15.0",
    "globals": "^15.0.0",
    "lit": "^3.2.1",
    "prettier": "^3.3.0",
    "rollup": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.0"
  }
}
